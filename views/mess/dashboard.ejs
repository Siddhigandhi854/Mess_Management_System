<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Mess Management System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script>
    // Translation system - Complete Marathi translation
    const translations = {
      en: {
        welcome: "Welcome",
        dashboard: "Dashboard",
        attendance: "Attendance",
        complaints: "Complaints",
        payments: "Payments",
        menu: "Menu",
        messOff: "Mess Off",
        settings: "Settings",
        login: "Login",
        register: "Register",
        logout: "Logout",
        profile: "Profile",
        home: "Home",
        quickStats: "Quick Stats",
        totalStudents: "Total Students",
        todayAttendance: "Today's Attendance",
        pendingPayments: "Pending Payments",
        activeComplaints: "Active Complaints",
        managementTools: "Management Tools",
        todaysMenu: "Today's Menu",
        breakfast: "Breakfast",
        lunch: "Lunch",
        dinner: "Dinner",
        recentComplaints: "Recent Complaints",
        noComplaints: "No complaints found",
        markAttendance: "Mark Attendance",
        viewMenu: "View Menu",
        submitComplaint: "Submit Complaint",
        makePayment: "Make Payment",
        requestMessOff: "Request Mess Off",
        studentDashboard: "Student Dashboard",
        adminDashboard: "Admin Dashboard",
        staffDashboard: "Staff Dashboard",
        foodCalculator: "Food Calculator",
        dailyFoodRequirements: "Daily Food Requirements",
        studentsPresent: "Students Present",
        riceKg: "Rice (kg)",
        wheatFlourKg: "Wheat Flour (kg)",
        dalLiters: "Dal (liters)",
        vegetablesKg: "Vegetables (kg)",
        rotis: "Rotis",
        perStudentBreakdown: "Per Student Breakdown",
        totalStudents: "Total Students",
        activeToday: "Active Today",
        messOff: "Mess Off",
        pendingBills: "Pending Bills",
        quickStats: "Quick Stats"
      },
      mr: {
        welcome: "स्वागत",
        dashboard: "डॅशबोर्ड",
        attendance: "उपस्थिती",
        complaints: "तक्राव",
        payments: "रक्कमे",
        menu: "मेनू",
        messOff: "मेस बंद",
        settings: "सेटिंग्ज",
        login: "लॉगिन",
        register: "नोंदणी करा",
        logout: "लॉगआउट",
        profile: "प्रोफाइल",
        home: "होम",
        quickStats: "जलद आकडेवारी",
        totalStudents: "एकूण विद्यार्थी",
        todayAttendance: "आजची उपस्थिती",
        pendingPayments: "प्रलंबित रक्कमे",
        activeComplaints: "सक्रिय तक्रार",
        managementTools: "व्यवस्थापन साधने",
        todaysMenu: "आजचे मेनू",
        breakfast: "नाश्ता",
        lunch: "दुपारचे जेवण",
        dinner: "रात्रीचे जेवण",
        recentComplaints: "अलीकडील तक्रार",
        noComplaints: "कोणतेही तक्रार सापडले नाही",
        markAttendance: "उपस्थिती नक्का करा",
        viewMenu: "मेनू पहा",
        submitComplaint: "तक्रार सबमिट करा",
        makePayment: "रक्कम करा",
        requestMessOff: "मेस बंद विनंती करा",
        studentDashboard: "विद्यार्थी डॅशबोर्ड",
        adminDashboard: "अडमिन डॅशबोर्ड",
        staffDashboard: "स्टाफ डॅशबोर्ड",
        foodCalculator: "अन्न कॅल्क्युलेटर",
        dailyFoodRequirements: "दैनिक अन्न आवश्यकता",
        studentsPresent: "उपस्थित विद्यार्थी:",
        riceKg: "तांदूळ (किलो)",
        wheatFlourKg: "गहू चे पीठ (किलो)",
        dalLiters: "डाळ (लिटर)",
        vegetablesKg: "भाज्या (किलो)",
        rotis: "रोटी",
        perStudentBreakdown: "प्रति विद्यार्थी तपशील",
        totalStudents: "एकूण विद्यार्थी",
        activeToday: "आज सक्रिय",
        messOffCount: "मेस बंद",
        pendingBills: "प्रलंबित बिले",
        quickStats: "जलद आकडेवारी"
      }
    };

    function updatePageLanguage() {
      const lang = localStorage.getItem('selectedLanguage') || 'en';
      
      // Update all translatable elements
      document.querySelectorAll('[data-translate]').forEach(element => {
        const key = element.getAttribute('data-translate');
        if (translations[lang][key]) {
          element.textContent = translations[lang][key];
        }
      });
    }

    // Language selection functionality
    document.addEventListener('DOMContentLoaded', function() {
      const languageSelect = document.getElementById('languageSelect');
      if (languageSelect) {
        languageSelect.addEventListener('change', function() {
          const selectedLanguage = this.value;
          localStorage.setItem('selectedLanguage', selectedLanguage);
          updatePageLanguage();
        });

        // Set initial language
        const savedLanguage = localStorage.getItem('selectedLanguage');
        if (savedLanguage) {
          languageSelect.value = savedLanguage;
        }
        updatePageLanguage();
      }
      
      // Also update language immediately in case header is loaded after
      setTimeout(updatePageLanguage, 100);
    });

    tailwind.config = {
      theme: {
        extend: {
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
            'bounce-slow': 'bounce 2s infinite',
          },
          keyframes: {
            float: {
              '0%, 100%': { transform: 'translateY(0px)' },
              '50%': { transform: 'translateY(-10px)' },
            },
            bounce: {
              '0%, 100%': { transform: 'translateY(0)' },
              '50%': { transform: 'translateY(-20px)' },
            }
          }
        }
      }
    }
  </script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #1a1a2e;
      background-image: 
        linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.6)),
        url('https://images.pexels.com/photos/262978/pexels-photo-262978.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=1');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      min-height: 100vh;
      position: relative;
      background-repeat: no-repeat;
    }
    body::before {
      content: '';
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(135deg, 
        rgba(59, 130, 246, 0.15) 0%, 
        rgba(147, 51, 234, 0.1) 50%, 
        rgba(236, 72, 153, 0.1) 100%);
      pointer-events: none;
      z-index: 1;
    }
    .container {
      position: relative;
      z-index: 2;
    }
    .glass-morphism {
      background: rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 255, 255, 0.3);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
      position: relative;
      overflow: hidden;
    }
    .glass-morphism::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, 
        transparent, 
        rgba(255, 255, 255, 0.1), 
        transparent);
      transition: left 0.5s;
    }
    .glass-morphism:hover::before {
      left: 100%;
    }
    .glass-morphism:hover {
      box-shadow: 0 15px 50px rgba(0, 0, 0, 0.25);
      transform: translateY(-3px);
      border-color: rgba(255, 255, 255, 0.4);
    }
    .stat-card {
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(20px);
      border: 1px solid rgba(255, 255, 255, 0.25);
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      position: relative;
      overflow: hidden;
    }
    .stat-card::after {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
      opacity: 0;
      transition: opacity 0.3s;
    }
    .stat-card:hover::after {
      opacity: 1;
    }
    .stat-card:hover {
      transform: translateY(-8px) scale(1.02);
      box-shadow: 0 25px 60px rgba(0, 0, 0, 0.2);
      border-color: rgba(255, 255, 255, 0.35);
    }
    .hover-lift {
      transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      position: relative;
    }
    .hover-lift:hover {
      transform: translateY(-12px) scale(1.03);
      box-shadow: 0 30px 70px rgba(0, 0, 0, 0.25);
    }
    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .btn-primary::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.5s;
    }
    .btn-primary:hover::before {
      left: 100%;
    }
    .btn-primary:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(102, 126, 234, 0.4);
    }
    .animate-float {
      animation: float 6s ease-in-out infinite;
    }
    @keyframes float {
      0%, 100% { transform: translateY(0px); }
      50% { transform: translateY(-15px); }
    }
    .btn-success {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .btn-success::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.5s;
    }
    .btn-success:hover::before {
      left: 100%;
    }
    .btn-success:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(16, 185, 129, 0.4);
    }
    .btn-danger {
      background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .btn-danger::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
      transition: left 0.5s;
    }
    .btn-danger:hover::before {
      left: 100%;
    }
    .btn-danger:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 30px rgba(239, 68, 68, 0.4);
    }
    .form-input {
      border: 2px solid rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.1);
      transition: all 0.3s ease;
      color: white;
    }
    .form-input:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.3);
      background: rgba(255, 255, 255, 0.2);
    }
    .form-input::placeholder {
      color: rgba(255, 255, 255, 0.7);
    }
    .icon-pulse {
      animation: iconPulse 2s infinite;
    }
    @keyframes iconPulse {
      0% { transform: scale(1); }
      50% { transform: scale(1.1); }
      100% { transform: scale(1); }
    }
    .text-glow {
      text-shadow: 0 0 20px rgba(255, 255, 255, 0.5);
    }
  </style>
</head>
<body>
  <%- include('../_header') %>
  <main class="container mx-auto px-6 py-12">
    <div class="mb-8 text-center">
      <div class="inline-block mb-4">
        <div class="w-24 h-24 bg-gradient-to-br from-blue-400 to-cyan-400 rounded-full flex items-center justify-center animate-float icon-pulse">
          <i class="fas fa-utensils text-white text-4xl"></i>
        </div>
      </div>
      <h1 class="text-5xl font-bold text-white mb-2 animate-pulse-slow text-glow" data-translate="welcome">Welcome, <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400"><%= currentUser.name %></span>!</h1>
      <p class="text-purple-200 text-lg" data-translate="managementTools">Mess Staff Dashboard - Manage Everything Here</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="stat-card rounded-xl p-6 border-l-4 border-blue-400 hover-lift">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-purple-200 font-semibold" data-translate="todayAttendance">Today's Attendance</p>
            <p class="text-3xl font-bold text-white mt-2"><%= todayCount %></p>
          </div>
          <div class="w-14 h-14 bg-blue-400 rounded-full flex items-center justify-center animate-pulse">
            <i class="fas fa-users text-white text-2xl"></i>
          </div>
        </div>
      </div>

      <div class="stat-card rounded-xl p-6 border-l-4 border-orange-400 hover-lift">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-purple-200 font-semibold" data-translate="activeComplaints">Pending Complaints</p>
            <p class="text-3xl font-bold text-white mt-2"><%= complaints.length %></p>
          </div>
          <div class="w-14 h-14 bg-orange-400 rounded-full flex items-center justify-center animate-pulse">
            <i class="fas fa-exclamation-triangle text-white text-2xl"></i>
          </div>
        </div>
      </div>

      <div class="stat-card rounded-xl p-6 border-l-4 border-green-400 hover-lift">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-purple-200 font-semibold">Total Balance</p>
            <p class="text-3xl font-bold text-green-300 mt-2">₹<%= unpaidBills.reduce((sum, bill) => sum + bill.amount, 0).toLocaleString() %></p>
          </div>
          <div class="w-14 h-14 bg-green-400 rounded-full flex items-center justify-center animate-pulse">
            <i class="fas fa-coins text-white text-2xl"></i>
          </div>
        </div>
      </div>

      <div class="stat-card rounded-xl p-6 border-l-4 border-red-400 hover-lift">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-purple-200 font-semibold">Unpaid Bills</p>
            <p class="text-3xl font-bold text-white mt-2"><%= unpaidBills.length %></p>
          </div>
          <div class="w-14 h-14 bg-red-400 rounded-full flex items-center justify-center animate-pulse">
            <i class="fas fa-file-invoice text-white text-2xl"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="glass-morphism rounded-xl p-8">
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-tools text-blue-400"></i> <span data-translate="managementTools">Management Tools</span>
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <a href="/mess/attendance" class="btn-primary text-white px-4 py-3 rounded-lg hover:shadow-xl font-bold text-lg transition hover:scale-105 transform block text-center">
              <div class="flex flex-col items-center gap-2">
                <div class="w-20 h-20 rounded-xl overflow-hidden border-3 border-white shadow-xl">
                  <img src="https://img.icons8.com/stickers/1200/attendance-mark.jpg">
                </div>
                <i class="fas fa-user-check"></i> <span data-translate="attendance">Attendance</span>
              </div>
            </a>
            <a href="/mess/complaints" class="btn-primary text-white px-4 py-3 rounded-lg hover:shadow-xl font-bold text-lg transition hover:scale-105 transform block text-center">
              <div class="flex flex-col items-center gap-2">
                <div class="w-20 h-20 rounded-xl overflow-hidden border-3 border-white shadow-xl">
                  <img src="https://c8.alamy.com/comp/2HEHM9A/complaints-text-on-red-round-grungy-texture-stamp-2HEHM9A.jpg" alt="Complaints" class="w-full h-full object-cover" onerror="this.src='https://picsum.photos/seed/help-desk-support/120/120.jpg'">
                </div>
                <i class="fas fa-tasks"></i> <span data-translate="complaints">Complaints</span>
              </div>
            </a>
            <a href="/mess/payments" class="btn-primary text-white px-4 py-3 rounded-lg hover:shadow-xl font-bold text-lg transition hover:scale-105 transform block text-center">
              <div class="flex flex-col items-center gap-2">
                <div class="w-20 h-20 rounded-xl overflow-hidden border-3 border-white shadow-xl">
                  <img src="https://www.creativefabrica.com/wp-content/uploads/2021/09/15/Money-finance-cash-payment-icon-Graphics-17346742-1.jpg" alt="Payments" class="w-full h-full object-cover" onerror="this.src='https://picsum.photos/seed/cash-payment/120/120.jpg'">
                </div>
                <i class="fas fa-money-bill"></i> <span data-translate="payments">Payments</span>
              </div>
            </a>
            <a href="/mess/menu" class="btn-primary text-white px-4 py-3 rounded-lg hover:shadow-xl font-bold text-lg transition hover:scale-105 transform block text-center">
              <div class="flex flex-col items-center gap-2">
                <div class="w-20 h-20 rounded-xl overflow-hidden border-3 border-white shadow-xl">
                  <img src="https://www.blueosa.com/wp-content/uploads/2020/01/the-best-top-10-indian-dishes.jpg" alt="Menu" class="w-full h-full object-cover" onerror="this.src='https://picsum.photos/seed/indian-meal-thali-fresh/120/120.jpg'">
                </div>
                <i class="fas fa-utensils"></i> <span data-translate="menu">Menu</span>
              </div>
            </a>
            <a href="/mess/messoff" class="btn-primary text-white px-4 py-3 rounded-lg hover:shadow-xl font-bold text-lg transition hover:scale-105 transform block text-center">
              <div class="flex flex-col items-center gap-2">
                <div class="w-20 h-20 rounded-xl overflow-hidden border-3 border-white shadow-xl">
                  <img src="https://picsum.photos/seed/calendar-leave-application-form/120/120.jpg" alt="Mess Off" class="w-full h-full object-cover" onerror="this.src='https://picsum.photos/seed/leave-calendar/120/120.jpg'">
                </div>
                <i class="fas fa-calendar"></i> <span data-translate="messOff">Mess Off</span>
              </div>
            </a>
            <a href="/mess/settings" class="btn-primary text-white px-4 py-3 rounded-lg hover:shadow-xl font-bold text-lg transition hover:scale-105 transform block text-center">
              <div class="flex flex-col items-center gap-2">
                <div class="w-20 h-20 rounded-xl overflow-hidden border-3 border-white shadow-xl">
                  <img src="https://static.vecteezy.com/system/resources/previews/021/190/084/original/settings-filled-icon-in-transparent-background-basic-app-and-web-ui-bold-line-icon-eps10-free-vector.jpg" alt="Settings" class="w-full h-full object-cover" onerror="this.src='https://picsum.photos/seed/gear-settings/120/120.jpg'">
                </div>
                <i class="fas fa-cog"></i> <span data-translate="settings">Settings</span>
              </div>
            </a>
          </div>
        </div>

        <div class="glass-morphism rounded-xl p-8 mt-8">
          <h3 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-exclamation-circle text-orange-400"></i> <span data-translate="recentComplaints">Recent Complaints</span>
          </h3>
          <div class="space-y-4">
            <% if (complaints.length === 0) { %>
              <div class="text-center py-8">
                <div class="w-16 h-16 bg-white bg-opacity-20 rounded-lg flex items-center justify-center mx-auto mb-4">
                  <i class="fas fa-check-circle text-white text-2xl"></i>
                </div>
                <p class="text-purple-200" data-translate="noComplaints">No pending complaints</p>
              </div>
            <% } else { %>
              <% complaints.forEach(complaint => { %>
                <div class="bg-gradient-to-r from-yellow-400 to-orange-400 p-4 rounded-lg hover:scale-105 transform transition-all duration-300">
                  <div class="flex items-start justify-between">
                    <div>
                      <p class="font-bold text-white"><%= complaint.subject %></p>
                      <p class="text-sm text-white mt-1">Reported by <%= complaint.student ? complaint.student.name : 'Unknown' %> - <%= new Date(complaint.createdAt).toLocaleDateString() %></p>
                    </div>
                    <span class="bg-yellow-300 text-yellow-900 px-3 py-1 rounded-full text-xs font-bold">Pending</span>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>

      <div>
        <div class="glass-morphism rounded-xl p-8">
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-utensils text-orange-400"></i> <span data-translate="todaysMenu">Today's Menu</span>
          </h3>
          <div class="relative h-80 rounded-xl overflow-hidden">
            <img src="https://img.freepik.com/premium-photo/veg-thali-from-indian-cuisine-food-platter-consists-variety-veggiespaneer-dish-lentils-jeera-riceroti-sweet-dish-curd-onion-etc-selective-focus_726363-844.jpg?w=2000" alt="Indian Meal Thali" class="w-full h-full object-cover" onerror="this.src='https://picsum.photos/seed/colorful-indian-thali-food/800/500.jpg'">
            <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-6 bg-gradient-to-t from-black/80 to-transparent">
              <p class="text-white font-bold text-xl">🍽️ Traditional Indian Thali</p>
              <p class="text-white text-base">Complete meal with fresh roti, dal, rice, sabzi, salad & pickle</p>
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mt-6">
            <div class="bg-gradient-to-r from-yellow-400 to-orange-400 rounded-lg p-4 hover:scale-105 transform transition-all duration-300">
              <p class="font-bold text-white text-sm" data-translate="breakfast">🌅 Breakfast</p>
              <p class="text-sm text-white mt-2">Poha, Jalebi, Tea/Milk</p>
            </div>
            <div class="bg-gradient-to-r from-blue-400 to-cyan-400 rounded-lg p-4 hover:scale-105 transform transition-all duration-300">
              <p class="font-bold text-white text-sm" data-translate="lunch">🍽️ Lunch</p>
              <p class="text-sm text-white mt-2">Roti, Chana Masala, Rice, Dal</p>
            </div>
            <div class="bg-gradient-to-r from-purple-400 to-pink-400 rounded-lg p-4 hover:scale-105 transform transition-all duration-300">
              <p class="font-bold text-white text-sm" data-translate="dinner">🍽️ Dinner</p>
              <p class="text-sm text-white mt-2">Roti, Sabzi, Dal, Salad</p>
            </div>
          </div>
          </div>
        </div>

        <div class="glass-morphism rounded-xl p-8 mt-8">
          <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-3">
            <i class="fas fa-calculator text-blue-400"></i> <span data-translate="foodCalculator">Food Calculator</span>
          </h3>
          <div class="space-y-4">
            <div class="bg-gradient-to-r from-blue-400 to-purple-400 rounded-lg p-4">
              <div class="text-white">
                <p class="font-bold mb-2" data-translate="dailyFoodRequirements">🍚️ Daily Food Requirements</p>
                <div class="grid grid-cols-2 gap-4 text-sm">
                  <div>
                    <span class="text-purple-200" data-translate="studentsPresent">Students Present:</span>
                    <span class="font-bold"><%= todayCount %></span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="riceKg">Rice (kg):</span>
                    <span class="font-bold"><%= (todayCount * 0.2).toFixed(1) %></span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="wheatFlourKg">Wheat Flour (kg):</span>
                    <span class="font-bold"><%= (todayCount * 0.15).toFixed(1) %></span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="dalLiters">Dal (liters):</span>
                    <span class="font-bold"><%= (todayCount * 0.1).toFixed(1) %></span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="vegetablesKg">Vegetables (kg):</span>
                    <span class="font-bold"><%= (todayCount * 0.15).toFixed(1) %></span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="rotis">Rotis:</span>
                    <span class="font-bold"><%= (todayCount * 2) %></span>
                  </div>
                </div>
              </div>
            </div>
            
            <div class="bg-gradient-to-r from-green-400 to-teal-400 rounded-lg p-4">
              <div class="text-white">
                <p class="font-bold mb-2" data-translate="perStudentBreakdown">📊 Per Student Breakdown</p>
                <div class="grid grid-cols-2 gap-4 text-sm">
                  <div>
                    <span class="text-purple-200" data-translate="riceKg">Rice:</span>
                    <span class="font-bold">200g</span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="wheatFlourKg">Flour:</span>
                    <span class="font-bold">150g</span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="dalLiters">Dal:</span>
                    <span class="font-bold">100ml</span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="vegetablesKg">Vegetables:</span>
                    <span class="font-bold">150g</span>
                  </div>
                  <div>
                    <span class="text-purple-200" data-translate="rotis">Rotis:</span>
                    <span class="font-bold">2 pcs</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="glass-morphism rounded-xl p-8 mt-8">
          <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-3">
            <i class="fas fa-chart-bar text-green-400"></i> <span data-translate="quickStats">Quick Stats</span>
          </h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center">
              <span class="text-purple-200" data-translate="totalStudents">Total Students</span>
              <span class="text-white font-bold"><%= totalStudents || 0 %></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-purple-200" data-translate="activeToday">Active Today</span>
              <span class="text-white font-bold"><%= todayCount %></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-purple-200" data-translate="messOff">Mess Off</span>
              <span class="text-white font-bold"><%= upcomingMessOffs.length %></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-purple-200" data-translate="pendingBills">Pending Bills</span>
              <span class="text-white font-bold"><%= unpaidBills.length %></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('../_footer') %>
  
  <script>
    // Force language update when page loads
    setTimeout(function() {
      const lang = localStorage.getItem('selectedLanguage') || 'en';
      document.querySelectorAll('[data-translate]').forEach(element => {
        const key = element.getAttribute('data-translate');
        if (translations[lang] && translations[lang][key]) {
          element.textContent = translations[lang][key];
        }
      });
    }, 200);
  </script>
</body>
</html>
