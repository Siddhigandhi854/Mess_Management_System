<!DOCTYPE html>

<html lang="en">

<head>

  <meta charset="UTF-8">

  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title><%= title %> - Mess Management System</title>

  <script src="https://cdn.tailwindcss.com"></script>

  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

  <script>

    // Translation system
    const translations = {
      en: {
        registerTitle: "Create Account",
        registerSubtitle: "Join MessHub and get started today",
        fullName: "Full Name",
        emailAddress: "Email Address",
        password: "Password",
        role: "Role",
        student: "Student",
        messStaff: "Mess Staff",
        createAccount: "Create Account",
        alreadyHaveAccount: "Already have an account?",
        loginHere: "Login here",
        joinCommunity: "Join Our Community!",
        communityDesc: "Create an account and start managing your mess efficiently today.",
        communityFirst: "Community First",
        communityFirstDesc: "Connected with peers",
        easyManagement: "Easy Management",
        easyManagementDesc: "Simple and intuitive",
        getStartedFast: "Get Started Fast",
        getStartedFastDesc: "In just a few clicks",
        emailAlreadyRegistered: "Email already registered",
        somethingWentWrong: "Something went wrong"
      },
      mr: {
        registerTitle: "खाते तयार करा",
        registerSubtitle: "मेसहबमध्ये सामील होऊन आजच सुरुवात करा",
        fullName: "पूर्ण नाव",
        emailAddress: "ईमेल पत्ता",
        password: "पासवर्ड",
        role: "भूमिका",
        student: "विद्यार्थी",
        messStaff: "मेस कर्मचारी",
        createAccount: "खाते तयार करा",
        alreadyHaveAccount: "आधीच खाते आहे का?",
        loginHere: "येथे लॉगिन करा",
        joinCommunity: "आमच्या समुदायात सामील होवा!",
        communityDesc: "खाते तयार करा आणि आपले मेस कार्यक्षमतेने व्यवस्थापित करण्यास सुरुवात करा.",
        communityFirst: "समुदाय प्रथम",
        communityFirstDesc: "सहकाऱ्यांशी जोडले",
        easyManagement: "सोपे व्यवस्थापन",
        easyManagementDesc: "साधे आणि अंतर्ज्ञानी",
        getStartedFast: "जलद सुरुवात करा",
        getStartedFastDesc: "फक्त काही क्लिकमध्ये",
        emailAlreadyRegistered: "ईमेल आधीच नोंदणीकृत आहे",
        somethingWentWrong: "काहीतरी चूक झाली"
      }
    };

    function updatePageLanguage() {
      const lang = localStorage.getItem('selectedLanguage') || 'en';
      
      // Update all translatable elements
      document.querySelectorAll('[data-translate]').forEach(element => {
        const key = element.getAttribute('data-translate');
        if (translations[lang][key]) {
          element.textContent = translations[lang][key];
        }
      });
    }

    // Language selection functionality
    document.addEventListener('DOMContentLoaded', function() {
      const languageSelect = document.getElementById('languageSelect');
      if (languageSelect) {
        languageSelect.addEventListener('change', function() {
          const selectedLanguage = this.value;
          localStorage.setItem('selectedLanguage', selectedLanguage);
          updatePageLanguage();
        });

        // Set initial language
        const savedLanguage = localStorage.getItem('selectedLanguage');
        if (savedLanguage) {
          languageSelect.value = savedLanguage;
        }
        updatePageLanguage();
      }
    });

    tailwind.config = {

      theme: {

        extend: {

          animation: {

            'float': 'float 6s ease-in-out infinite',

            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',

          },

          keyframes: {

            float: {

              '0%, 100%': { transform: 'translateY(0px)' },

              '50%': { transform: 'translateY(-10px)' },

            }

          }

        }

      }

    }

  </script>

  <style>

    * {

      margin: 0;

      padding: 0;

      box-sizing: border-box;

    }

    body {

      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;

      background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('https://images.unsplash.com/photo-1414235077428-338989a2e8c0?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1470&q=80');

      background-size: cover;

      background-position: center;

      background-attachment: fixed;

      min-height: 100vh;

    }

    .glass-morphism {

      background: rgba(255, 255, 255, 0.1);

      backdrop-filter: blur(10px);

      border: 1px solid rgba(255, 255, 255, 0.2);

    }

    .navbar-gradient {

      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);

    }

    .btn-primary {

      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);

      transition: all 0.3s ease;

    }

    .btn-primary:hover {

      transform: translateY(-2px);

      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);

    }

    .form-input {

      border: 2px solid rgba(255, 255, 255, 0.3);

      background: rgba(255, 255, 255, 0.1);

      transition: all 0.3s ease;

      color: white;

    }

    .form-input:focus {

      border-color: #667eea;

      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.3);

      background: rgba(255, 255, 255, 0.2);

    }

    .form-input::placeholder {

      color: rgba(255, 255, 255, 0.7);

    }

  </style>

</head>

<body>

  <%- include('../_header') %>

  <main class="container mx-auto px-6 py-20">

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">

      <div class="hidden lg:block">

        <div class="glass-morphism rounded-2xl p-12 text-white animate-float">

          <h2 class="text-4xl font-bold mb-6 bg-gradient-to-r from-green-400 to-teal-400 bg-clip-text text-transparent" data-translate="joinCommunity">Join Our Community!</h2>

          <p class="text-lg mb-8 text-purple-200" data-translate="communityDesc">Create an account and start managing your mess efficiently today.</p>

          <div class="space-y-6">

            <div class="flex items-center gap-4 hover:scale-105 transform transition-all duration-300">

              <div class="w-12 h-12 bg-white bg-opacity-20 rounded-lg flex items-center justify-center">

                <i class="fas fa-users text-white text-xl"></i>

              </div>

              <div>

                <h4 class="font-bold text-lg" data-translate="communityFirst">Community First</h4>

                <p class="text-purple-200 text-sm" data-translate="communityFirstDesc">Connected with peers</p>

              </div>

            </div>

            <div class="flex items-center gap-4 hover:scale-105 transform transition-all duration-300">

              <div class="w-12 h-12 bg-white bg-opacity-20 rounded-lg flex items-center justify-center">

                <i class="fas fa-tasks text-white text-xl"></i>

              </div>

              <div>

                <h4 class="font-bold text-lg" data-translate="easyManagement">Easy Management</h4>

                <p class="text-purple-200 text-sm" data-translate="easyManagementDesc">Simple and intuitive</p>

              </div>

            </div>

            <div class="flex items-center gap-4 hover:scale-105 transform transition-all duration-300">

              <div class="w-12 h-12 bg-white bg-opacity-20 rounded-lg flex items-center justify-center">

                <i class="fas fa-rocket text-white text-xl"></i>

              </div>

              <div>

                <h4 class="font-bold text-lg" data-translate="getStartedFast">Get Started Fast</h4>

                <p class="text-purple-200 text-sm" data-translate="getStartedFastDesc">In just a few clicks</p>

              </div>

            </div>

          </div>

        </div>

      </div>



      <div>

        <div class="glass-morphism rounded-2xl p-8 md:p-12">

          <div class="text-center mb-8">

            <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-teal-400 rounded-lg flex items-center justify-center mx-auto mb-4 animate-pulse-slow">

              <i class="fas fa-user-plus text-white text-2xl"></i>

            </div>

            <h2 class="text-3xl font-bold text-white" data-translate="registerTitle">Create Account</h2>

            <p class="text-purple-200 mt-2" data-translate="registerSubtitle">Join MessHub and get started today</p>

          </div>



          <% if (error) { %>

            <div class="bg-gradient-to-r from-red-400 to-pink-400 text-white px-4 py-4 rounded-lg mb-6">

              <div class="flex items-center">

                <i class="fas fa-exclamation-circle mr-3"></i>

                <p><%= error %></p>

              </div>

            </div>

          <% } %>



          <form method="POST" action="/auth/register" class="space-y-5">

            <div>

              <label class="block text-white font-bold mb-2" for="name">

                <i class="fas fa-user mr-2"></i><span data-translate="fullName">Full Name</span>

              </label>

              <input class="form-input w-full px-4 py-3 rounded-lg" type="text" id="name" name="name" placeholder="John Doe" required>

            </div>



            <div>

              <label class="block text-white font-bold mb-2" for="email">

                <i class="fas fa-envelope mr-2"></i><span data-translate="emailAddress">Email Address</span>

              </label>

              <input class="form-input w-full px-4 py-3 rounded-lg" type="email" id="email" name="email" placeholder="you@example.com" required>

            </div>



            <div>

              <label class="block text-white font-bold mb-2" for="password">

                <i class="fas fa-lock mr-2"></i><span data-translate="password">Password</span>

              </label>

              <input class="form-input w-full px-4 py-3 rounded-lg" type="password" id="password" name="password" placeholder="••••••••" required>

            </div>



            <div>

              <label class="block text-white font-bold mb-2" for="role">

                <i class="fas fa-id-card mr-2"></i><span data-translate="role">Role</span>

              </label>

              <select class="form-input w-full px-4 py-3 rounded-lg" id="role" name="role">

                <option value="student" data-translate="student">Student</option>

                <option value="messKaki" data-translate="messStaff">Mess Staff</option>

              </select>

            </div>



            <button class="btn-primary w-full text-white px-6 py-3 rounded-lg hover:shadow-xl font-bold text-lg transition hover:scale-105 transform" type="submit">

              <i class="fas fa-user-plus mr-2"></i><span data-translate="createAccount">Create Account</span>

            </button>

          </form>



          <div class="mt-8 text-center">

            <p class="text-purple-200" data-translate="alreadyHaveAccount">Already have an account? 

              <a href="/auth/login" class="text-green-400 font-bold hover:text-teal-400 transition hover:scale-105 transform" data-translate="loginHere">Login here</a>

            </p>

          </div>

        </div>

      </div>

    </div>

  </main>

  <%- include('../_footer') %>

</body>

</html>

