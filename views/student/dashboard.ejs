<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Mess Management System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script>
    // Translation system - Complete Marathi translation for Student Dashboard
    const translations = {
      en: {
        welcome: "Welcome",
        studentDashboard: "Student Dashboard",
        quickActions: "Quick Actions",
        markAttendance: "Mark Attendance",
        viewMenu: "View Menu",
        submitComplaint: "Submit Complaint",
        makePayment: "Make Payment",
        requestMessOff: "Request Mess Off",
        todayAttendance: "Today's Attendance",
        pendingComplaints: "Pending Complaints",
        paymentStatus: "Payment Status",
        upcomingMenu: "Upcoming Menu",
        attendanceHistory: "Attendance History",
        complaintHistory: "Complaint History",
        paymentHistory: "Payment History",
        messOffRequests: "Mess Off Requests",
        profile: "Profile",
        settings: "Settings",
        logout: "Logout",
        home: "Home",
        totalStudents: "Total Students",
        activeToday: "Active Today",
        pendingPayments: "Pending Payments",
        activeComplaints: "Active Complaints",
        upcomingHolidays: "Upcoming Holidays",
        monthlyStats: "Monthly Stats",
        attendanceRate: "Attendance Rate",
        messEfficiency: "Mess Efficiency",
        quickStats: "Quick Stats",
        recentActivity: "Recent Activity",
        notifications: "Notifications",
        noNotifications: "No new notifications",
        viewAll: "View All",
        todaySchedule: "Today's Schedule",
        breakfast: "Breakfast",
        lunch: "Lunch",
        dinner: "Dinner",
        messTimings: "Mess Timings",
        breakfastTime: "7:00 AM - 9:00 AM",
        lunchTime: "12:00 PM - 2:00 PM",
        dinnerTime: "7:00 PM - 9:00 PM",
        contactInfo: "Contact Information",
        messManager: "Mess Manager",
        emergencyContact: "Emergency Contact",
        helpDesk: "Help Desk"
      },
      mr: {
        welcome: "स्वागत",
        studentDashboard: "विद्यार्थी डॅशबोर्ड",
        quickActions: "जलद कृती",
        markAttendance: "उपस्थिती नक्का करा",
        viewMenu: "मेनू पहा",
        submitComplaint: "तक्रार सबमिट करा",
        makePayment: "रक्कम करा",
        requestMessOff: "मेस बंद विनंती करा",
        todayAttendance: "आजची उपस्थिती",
        pendingComplaints: "प्रलंबित तक्रार",
        paymentStatus: "रक्कम स्थिती",
        upcomingMenu: "आगामी मेनू",
        attendanceHistory: "उपस्थिती इतिहास",
        complaintHistory: "तक्रार इतिहास",
        paymentHistory: "रक्कम इतिहास",
        messOffRequests: "मेस बंद विनंत्या",
        profile: "प्रोफाइल",
        settings: "सेटिंग्ज",
        logout: "लॉगआउट",
        home: "होम",
        totalStudents: "एकूण विद्यार्थी",
        activeToday: "आज सक्रिय",
        pendingPayments: "प्रलंबित रक्कमे",
        activeComplaints: "सक्रिय तक्रार",
        upcomingHolidays: "आगामी सुट्ट्या",
        monthlyStats: "मासिक आकडेवारी",
        attendanceRate: "उपस्थिती दर",
        messEfficiency: "मेस दक्षता",
        quickStats: "जलद आकडेवारी",
        recentActivity: "अलीकडील क्रियाकलाप",
        notifications: "सूचना",
        noNotifications: "कोणत्याही नवीन सूचना नाहीत",
        viewAll: "सर्व पहा",
        todaySchedule: "आजचे वेळापत्रक",
        breakfast: "नाश्ता",
        lunch: "दुपारचे जेवण",
        dinner: "रात्रीचे जेवण",
        messTimings: "मेस वेळ",
        breakfastTime: "सकाळी 7:00 - 9:00",
        lunchTime: "दुपारी 12:00 - 2:00",
        dinnerTime: "रात्री 7:00 - 9:00",
        contactInfo: "संपर्क माहिती",
        messManager: "मेस व्यवस्थापक",
        emergencyContact: "आपत्कालीन संपर्क",
        helpDesk: "मदत डेस्क"
      }
    };

    function updatePageLanguage() {
      const lang = localStorage.getItem('selectedLanguage') || 'en';
      
      // Update all translatable elements
      document.querySelectorAll('[data-translate]').forEach(element => {
        const key = element.getAttribute('data-translate');
        if (translations[lang][key]) {
          element.textContent = translations[lang][key];
        }
      });
    }

    // Language selection functionality
    document.addEventListener('DOMContentLoaded', function() {
      const languageSelect = document.getElementById('languageSelect');
      if (languageSelect) {
        languageSelect.addEventListener('change', function() {
          const selectedLanguage = this.value;
          localStorage.setItem('selectedLanguage', selectedLanguage);
          updatePageLanguage();
        });

        // Set initial language
        const savedLanguage = localStorage.getItem('selectedLanguage');
        if (savedLanguage) {
          languageSelect.value = savedLanguage;
        }
        updatePageLanguage();
      }
      
      // Also update language immediately in case header is loaded after
      setTimeout(updatePageLanguage, 100);
    });

    tailwind.config = {
      theme: {
        extend: {
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
          },
          keyframes: {
            float: {
              '0%, 100%': { transform: 'translateY(0px)' },
              '50%': { transform: 'translateY(-10px)' },
            }
          }
        }
      }
    }
  </script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-color: #2d1b1b;
      background-image: 
        linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.7)),
        url('https://images.unsplash.com/photo-1512058564366-18560ea541a6?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1470&q=80');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      min-height: 100vh;
      position: relative;
      background-repeat: no-repeat;
    }
    .glass-morphism {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(15px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      border-radius: 16px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }
    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
    }
  </style>
</head>
<body>
  <%- include('../_header') %>
  <main class="container mx-auto px-6 py-12">
    <div class="mb-8 text-center">
      <h1 class="text-5xl font-bold text-white mb-2 animate-pulse-slow"><span data-translate="welcome">Welcome</span>, <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-cyan-400"><%= currentUser.name %></span>!</h1>
      <p class="text-purple-200 text-lg" data-translate="studentDashboard">Student Dashboard - Track Your Mess Activities</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">
      <div class="glass-morphism text-white rounded-xl p-6 border-l-4 border-green-400 hover:scale-105 transform transition-all duration-300">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-purple-200 font-semibold" data-translate="todayAttendance">Today's Attendance</p>
            <p class="text-3xl font-bold text-white mt-2">Present</p>
          </div>
          <div class="w-14 h-14 bg-green-400 rounded-full flex items-center justify-center animate-pulse">
            <i class="fas fa-check-circle text-white text-2xl"></i>
          </div>
        </div>
      </div>

      <div class="glass-morphism text-white rounded-xl p-6 border-l-4 border-yellow-400 hover:scale-105 transform transition-all duration-300">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-purple-200 font-semibold" data-translate="pendingPayments">Pending Payments</p>
            <p class="text-3xl font-bold text-white mt-2">₹<%= unpaidBills.reduce((sum, bill) => sum + bill.amount, 0).toLocaleString() %></p>
          </div>
          <div class="w-14 h-14 bg-yellow-400 rounded-full flex items-center justify-center animate-pulse">
            <i class="fas fa-wallet text-white text-2xl"></i>
          </div>
        </div>
      </div>

      <div class="glass-morphism text-white rounded-xl p-6 border-l-4 border-blue-400 hover:scale-105 transform transition-all duration-300">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-purple-200 font-semibold">Your Balance</p>
            <p class="text-3xl font-bold text-blue-300 mt-2">₹<%= (unpaidBills.reduce((sum, bill) => sum + bill.amount, 0)).toLocaleString() %></p>
          </div>
          <div class="w-14 h-14 bg-blue-400 rounded-full flex items-center justify-center animate-pulse">
            <i class="fas fa-coins text-white text-2xl"></i>
          </div>
        </div>
      </div>

      <div class="glass-morphism text-white rounded-xl p-6 border-l-4 border-red-400 hover:scale-105 transform transition-all duration-300">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-purple-200 font-semibold">Messages</p>
            <p class="text-3xl font-bold text-white mt-2">3</p>
          </div>
          <div class="w-14 h-14 bg-red-400 rounded-full flex items-center justify-center animate-pulse">
            <i class="fas fa-bell text-white text-2xl"></i>
          </div>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="glass-morphism text-white rounded-xl p-8">
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-bolt text-yellow-400"></i> <span data-translate="quickActions">Quick Actions</span>
          </h2>
          <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
            <a href="/student/attendance" class="bg-gradient-to-r from-green-400 to-green-600 text-white py-3 rounded-lg font-bold hover:shadow-xl transition flex items-center justify-center gap-2 hover:scale-105 transform block text-center">
              <i class="fas fa-user-check"></i> <span data-translate="markAttendance">Mark Attendance</span>
            </a>
            <a href="/student/payments" class="bg-gradient-to-r from-yellow-400 to-orange-400 text-white py-3 rounded-lg font-bold hover:shadow-xl transition flex items-center justify-center gap-2 hover:scale-105 transform block text-center">
              <i class="fas fa-credit-card"></i> <span data-translate="makePayment">Pay Bill</span>
            </a>
            <a href="/student/messoff" class="bg-gradient-to-r from-red-400 to-pink-400 text-white py-3 rounded-lg font-bold hover:shadow-xl transition flex items-center justify-center gap-2 hover:scale-105 transform block text-center">
              <i class="fas fa-calendar-times"></i> <span data-translate="requestMessOff">Mess Off</span>
            </a>
            <a href="/student/menu" class="bg-gradient-to-r from-blue-400 to-cyan-400 text-white py-3 rounded-lg font-bold hover:shadow-xl transition flex items-center justify-center gap-2 hover:scale-105 transform block text-center">
              <i class="fas fa-utensils"></i> <span data-translate="viewMenu">View Menu</span>
            </a>
            <a href="/student/complaints" class="bg-gradient-to-r from-purple-400 to-purple-600 text-white py-3 rounded-lg font-bold hover:shadow-xl transition flex items-center justify-center gap-2 hover:scale-105 transform block text-center">
              <i class="fas fa-exclamation-circle"></i> <span data-translate="submitComplaint">Complaint</span>
            </a>
            <a href="/student/settings" class="bg-gradient-to-r from-gray-400 to-gray-600 text-white py-3 rounded-lg font-bold hover:shadow-xl transition flex items-center justify-center gap-2 hover:scale-105 transform block text-center">
              <i class="fas fa-cog"></i> <span data-translate="settings">Settings</span>
            </a>
          </div>
        </div>
      </div>

      <div>
        <div class="glass-morphism text-white rounded-xl p-8">
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-utensils text-orange-400"></i> <span data-translate="upcomingMenu">Upcoming Menu</span>
          </h2>
          <div class="space-y-4">
            <div class="bg-gradient-to-r from-orange-400 to-red-400 rounded-lg p-4 hover:scale-105 transform transition-all duration-300">
              <p class="font-bold text-white">Thursday</p>
              <p class="text-sm text-white mt-1"><i class="fas fa-sun mr-2 text-yellow-300"></i>Roti, Dal, Vegetable</p>
              <p class="text-sm text-white"><i class="fas fa-moon mr-2 text-blue-300"></i>Rice, Curry, Salad</p>
            </div>
            <div class="bg-gradient-to-r from-blue-400 to-purple-400 rounded-lg p-4 hover:scale-105 transform transition-all duration-300">
              <p class="font-bold text-white">Friday</p>
              <p class="text-sm text-white mt-1"><i class="fas fa-sun mr-2 text-yellow-300"></i>Paratha, Pickle</p>
              <p class="text-sm text-white"><i class="fas fa-moon mr-2 text-blue-300"></i>Biryani, Raita</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('../_footer') %>
  
  <script>
    // Force language update when page loads
    setTimeout(function() {
      const lang = localStorage.getItem('selectedLanguage') || 'en';
      document.querySelectorAll('[data-translate]').forEach(element => {
        const key = element.getAttribute('data-translate');
        if (translations[lang] && translations[lang][key]) {
          element.textContent = translations[lang][key];
        }
      });
    }, 200);
  </script>
</body>
</html>
