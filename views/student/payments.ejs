<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Mess Management System</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          animation: {
            'float': 'float 6s ease-in-out infinite',
            'pulse-slow': 'pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite',
          },
          keyframes: {
            float: {
              '0%, 100%': { transform: 'translateY(0px)' },
              '50%': { transform: 'translateY(-10px)' },
            }
          }
        }
      }
    }
  </script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background-image: linear-gradient(rgba(0, 0, 0, 0.4), rgba(0, 0, 0, 0.4)), url('https://images.unsplash.com/photo-1512058564366-18560ea541a6?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1470&q=80');
      background-size: cover;
      background-position: center;
      background-attachment: fixed;
      min-height: 100vh;
    }
    .glass-morphism {
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }
    .btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      transition: all 0.3s ease;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(102, 126, 234, 0.3);
    }
    .btn-success {
      background: linear-gradient(135deg, #10b981 0%, #059669 100%);
      transition: all 0.3s ease;
    }
    .btn-success:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
    }
    .form-input {
      border: 2px solid rgba(255, 255, 255, 0.3);
      background: rgba(255, 255, 255, 0.1);
      transition: all 0.3s ease;
      color: white;
    }
    .form-input:focus {
      border-color: #667eea;
      box-shadow: 0 0 0 3px rgba(102, 126, 234, 0.3);
      background: rgba(255, 255, 255, 0.2);
    }
    .form-input::placeholder {
      color: rgba(255, 255, 255, 0.7);
    }
  </style>
</head>
<body style="background-color: #2d1b1b; background-image: linear-gradient(rgba(0, 0, 0, 0.8), rgba(0, 0, 0, 0.7));">
  <%- include('../_header') %>
  <main class="container mx-auto px-6 py-12">
    <div class="mb-8">
      <h1 class="text-5xl font-bold text-white mb-2 animate-pulse-slow">Payment Center</h1>
      <p class="text-purple-200 text-lg">View and pay your mess bills</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2">
        <div class="glass-morphism rounded-xl p-8">
          <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-credit-card text-yellow-400"></i> Your Payment History
          </h2>
          
          <div class="space-y-4">
            <% if (payments.length === 0) { %>
              <div class="text-center py-12">
                <div class="w-16 h-16 bg-white bg-opacity-20 rounded-lg flex items-center justify-center mx-auto mb-4">
                  <i class="fas fa-inbox text-white text-2xl"></i>
                </div>
                <p class="text-purple-200 text-lg">No payment records found</p>
                <p class="text-purple-300 text-sm">Your payment history will appear here once you start making payments</p>
              </div>
            <% } else { %>
              <!-- Payment Record 1 -->
              <div class="bg-white bg-opacity-10 rounded-lg p-6 hover:scale-105 transform transition-all duration-300">
                <div class="flex justify-between items-start mb-4">
                  <div>
                    <h3 class="text-white font-bold text-lg"><%= payments[0].month ? new Date(2024, payments[0].month - 1).toLocaleString('default', { month: 'long' }) : 'Unknown Month' %> <%= payments[0].year %></h3>
                    <p class="text-purple-200 text-sm">Monthly Mess Fee</p>
                    <p class="text-purple-300 text-xs">Due: <%= payments[0].year %>-<%= payments[0].month %>-31</p>
                  </div>
                  <div class="text-right">
                    <span class="text-2xl font-bold text-white">₹<%= payments[0].amount %></span>
                    <span class="block text-sm px-3 py-1 rounded-full <%= payments[0].status === 'paid' ? 'bg-green-400' : 'bg-yellow-400' %> text-white mt-2"><%= payments[0].status %></span>
                  </div>
                </div>
                <div class="flex justify-between items-center">
                  <span class="text-purple-200 text-sm"><%= payments[0].status === 'paid' ? 'Paid on: ' + new Date(payments[0].paidAt).toLocaleDateString() : 'Status: Awaiting Payment' %></span>
                  <button class="bg-blue-400 text-white px-3 py-1 rounded text-sm hover:bg-blue-500 transition hover:scale-105 transform">
                    <i class="fas fa-download mr-1"></i> Receipt
                  </button>
                </div>
              </div>

              <% if (payments.length > 1) { %>
                <!-- Payment Record 2 -->
                <div class="bg-white bg-opacity-10 rounded-lg p-6 hover:scale-105 transform transition-all duration-300">
                  <div class="flex justify-between items-start mb-4">
                    <div>
                      <h3 class="text-white font-bold text-lg"><%= payments[1].month ? new Date(2024, payments[1].month - 1).toLocaleString('default', { month: 'long' }) : 'Unknown Month' %> <%= payments[1].year %></h3>
                      <p class="text-purple-200 text-sm">Monthly Mess Fee</p>
                      <p class="text-purple-300 text-xs">Due: <%= payments[1].year %>-<%= payments[1].month %>-31</p>
                    </div>
                    <div class="text-right">
                      <span class="text-2xl font-bold text-white">₹<%= payments[1].amount %></span>
                      <span class="block text-sm px-3 py-1 rounded-full <%= payments[1].status === 'paid' ? 'bg-green-400' : 'bg-yellow-400' %> text-white mt-2"><%= payments[1].status %></span>
                    </div>
                  </div>
                  <div class="flex justify-between items-center">
                    <span class="text-purple-200 text-sm"><%= payments[1].status === 'paid' ? 'Paid on: ' + new Date(payments[1].paidAt).toLocaleDateString() : 'Status: Awaiting Payment' %></span>
                    <button class="btn-success text-white px-4 py-2 rounded text-sm hover:scale-105 transform">
                      <i class="fas fa-credit-card mr-1"></i> Pay Now
                    </button>
                  </div>
                </div>
              <% } %>

              <% if (payments.length > 2) { %>
                <!-- Payment Record 3 -->
                <div class="bg-white bg-opacity-10 rounded-lg p-6 hover:scale-105 transform transition-all duration-300">
                  <div class="flex justify-between items-start mb-4">
                    <div>
                      <h3 class="text-white font-bold text-lg"><%= payments[2].month ? new Date(2024, payments[2].month - 1).toLocaleString('default', { month: 'long' }) : 'Unknown Month' %> <%= payments[2].year %></h3>
                      <p class="text-purple-200 text-sm">Monthly Mess Fee</p>
                      <p class="text-purple-300 text-xs">Due: <%= payments[2].year %>-<%= payments[2].month %>-31</p>
                    </div>
                    <div class="text-right">
                      <span class="text-2xl font-bold text-white">₹<%= payments[2].amount %></span>
                      <span class="block text-sm px-3 py-1 rounded-full <%= payments[2].status === 'paid' ? 'bg-green-400' : 'bg-yellow-400' %> text-white mt-2"><%= payments[2].status %></span>
                    </div>
                  </div>
                  <div class="flex justify-between items-center">
                    <span class="text-purple-200 text-sm"><%= payments[2].status === 'paid' ? 'Paid on: ' + new Date(payments[2].paidAt).toLocaleDateString() : 'Status: Awaiting Payment' %></span>
                    <button class="btn-success text-white px-4 py-2 rounded text-sm hover:scale-105 transform">
                      <i class="fas fa-credit-card mr-1"></i> Pay Now
                    </button>
                  </div>
                </div>
              <% } %>
            <% } %>
          </div>
        </div>

        <!-- QR Code Payment Section -->
        <div class="glass-morphism rounded-xl p-8 mt-8">
          <div class="text-center">
            <h2 class="text-3xl font-bold text-white mb-6 flex items-center justify-center gap-3">
              <i class="fas fa-qrcode text-blue-400"></i> QR Code Payment
            </h2>
            <p class="text-purple-200 text-lg mb-8">Scan the QR code to make instant payment</p>
            
            <div class="flex flex-col lg:flex-row items-center justify-center gap-8">
              <!-- QR Code Image -->
              <div class="bg-white p-6 rounded-xl shadow-2xl">
                <img src="/images/payment-qr-code.jpeg" 
                     alt="Payment QR Code" 
                     class="w-64 h-64 rounded-lg"
                     onerror="this.src='https://picsum.photos/seed/payment-qr-code/300/300.jpg'; this.alt='Default QR Code Placeholder'">
              </div>
              
              <!-- Payment Instructions -->
              <div class="text-left max-w-md">
                <h3 class="text-xl font-bold text-white mb-4">How to Pay:</h3>
                <div class="space-y-3">
                  <div class="flex items-start gap-3">
                    <span class="text-blue-400 font-bold">1.</span>
                    <p class="text-purple-200">Open any UPI payment app (PhonePe, Google Pay, PayTM, etc.)</p>
                  </div>
                  <div class="flex items-start gap-3">
                    <span class="text-blue-400 font-bold">2.</span>
                    <p class="text-purple-200">Scan the QR code with your phone camera</p>
                  </div>
                  <div class="flex items-start gap-3">
                    <span class="text-blue-400 font-bold">3.</span>
                    <p class="text-purple-200">Enter the payment amount (Mess fees: <span class="text-green-400 font-bold">Rs. 2000/month</span>)</p>
                  </div>
                  <div class="flex items-start gap-3">
                    <span class="text-blue-400 font-bold">4.</span>
                    <p class="text-purple-200">Complete the payment using your UPI PIN</p>
                  </div>
                  <div class="flex items-start gap-3">
                    <span class="text-blue-400 font-bold">5.</span>
                    <p class="text-purple-200">Save the payment receipt for your records</p>
                  </div>
                </div>
                
                <div class="mt-6 p-4 bg-yellow-400 bg-opacity-20 rounded-lg border border-yellow-400">
                  <p class="text-yellow-300 text-sm">
                    <i class="fas fa-info-circle mr-2"></i>
                    <strong>Note:</strong> After payment, please contact the mess admin to update your payment status.
                  </p>
                </div>
              </div>
            </div>
            
            <!-- UPI ID Display -->
            <div class="mt-8 p-4 bg-blue-400 bg-opacity-20 rounded-lg border border-blue-400 inline-block">
              <p class="text-blue-300">
                <i class="fas fa-mobile-alt mr-2"></i>
                <strong>UPI ID:</strong> <span class="font-mono">siddhigandhi53-2@okaxis</span>
                <button onclick="copyUPIId()" class="ml-4 bg-blue-400 text-white px-3 py-1 rounded text-sm hover:bg-blue-500 transition">
                  <i class="fas fa-copy mr-1"></i> Copy
                </button>
              </p>
            </div>
          </div>
        </div>
      </div>

      <div>
        <div class="glass-morphism rounded-xl p-8">
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-info-circle text-blue-400"></i> Payment Information
          </h3>
          <div class="space-y-4">
            <div class="bg-white bg-opacity-10 rounded-lg p-4">
              <h4 class="text-white font-bold mb-2">Monthly Fee Structure</h4>
              <p class="text-purple-200 text-sm">₹5,000 per month for regular mess service</p>
              <p class="text-purple-200 text-sm">Includes breakfast, lunch, and dinner</p>
            </div>
            
            <div class="bg-white bg-opacity-10 rounded-lg p-4">
              <h4 class="text-white font-bold mb-2">Payment Methods</h4>
              <p class="text-purple-200 text-sm">UPI, Cards, Net Banking, Cash</p>
              <p class="text-purple-200 text-sm">All major payment apps supported</p>
            </div>
            
            <div class="bg-white bg-opacity-10 rounded-lg p-4">
              <h4 class="text-white font-bold mb-2">Due Date</h4>
              <p class="text-purple-200 text-sm">Last day of each month</p>
              <p class="text-purple-200 text-sm">Late fees apply after due date</p>
            </div>
          </div>
        </div>

        <div class="glass-morphism rounded-xl p-8 mt-8">
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-chart-line text-green-400"></i> Payment Summary
          </h3>
          <div class="space-y-4">
            <div class="flex justify-between items-center">
              <span class="text-purple-200">Total Paid</span>
              <span class="text-green-400 font-bold">₹<%= payments.reduce((sum, p) => sum + (p.status === 'paid' ? p.amount : 0), 0) %></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-purple-200">Pending</span>
              <span class="text-yellow-400 font-bold">₹<%= payments.reduce((sum, p) => sum + (p.status === 'unpaid' ? p.amount : 0), 0) %></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-purple-200">Total Year</span>
              <span class="text-white font-bold">₹<%= payments.reduce((sum, p) => sum + p.amount, 0) %></span>
            </div>
          </div>
        </div>

        <div class="glass-morphism rounded-xl p-8 mt-8">
          <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <i class="fas fa-headset text-purple-400"></i> Support
          </h3>
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <i class="fas fa-phone text-purple-200"></i>
              <span class="text-purple-200">Payment Helpline: 1800-123-456</span>
            </div>
            <div class="flex items-center gap-3">
              <i class="fas fa-envelope text-purple-200"></i>
              <span class="text-purple-200">payments@mess.com</span>
            </div>
            <div class="flex items-center gap-3">
              <i class="fas fa-clock text-purple-200"></i>
              <span class="text-purple-200">24/7 Support Available</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include('../_footer') %>
  
  <script>
    function copyUPIId() {
      const upiId = 'siddhigandhi53-2@okaxis';
      navigator.clipboard.writeText(upiId).then(function() {
        // Show success message
        const button = event.target;
        const originalText = button.innerHTML;
        button.innerHTML = '<i class="fas fa-check mr-1"></i> Copied!';
        button.classList.remove('bg-blue-400', 'hover:bg-blue-500');
        button.classList.add('bg-green-400', 'hover:bg-green-500');
        
        // Reset button after 2 seconds
        setTimeout(function() {
          button.innerHTML = originalText;
          button.classList.remove('bg-green-400', 'hover:bg-green-500');
          button.classList.add('bg-blue-400', 'hover:bg-blue-500');
        }, 2000);
      }).catch(function(err) {
        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = upiId;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);
        
        // Show success message
        const button = event.target;
        const originalText = button.innerHTML;
        button.innerHTML = '<i class="fas fa-check mr-1"></i> Copied!';
        button.classList.remove('bg-blue-400', 'hover:bg-blue-500');
        button.classList.add('bg-green-400', 'hover:bg-green-500');
        
        setTimeout(function() {
          button.innerHTML = originalText;
          button.classList.remove('bg-green-400', 'hover:bg-green-500');
          button.classList.add('bg-blue-400', 'hover:bg-blue-500');
        }, 2000);
      });
    }
  </script>
</body>
</html>
