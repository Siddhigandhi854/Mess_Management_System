<header class="glass-morphism text-white shadow-lg sticky top-0 z-50">
  <div class="container mx-auto px-6 py-4">
    <div class="flex justify-between items-center">
      <div class="flex items-center gap-3 animate-float">
        <div class="w-12 h-12 bg-white rounded-xl flex items-center justify-center shadow-lg">
          <i class="fas fa-utensils text-purple-600 text-xl"></i>
        </div>
        <h1 class="text-3xl font-bold bg-gradient-to-r from-white to-purple-200 bg-clip-text text-transparent">MessHub</h1>
      </div>
      <nav class="flex gap-8 items-center">
        <!-- Language Dropdown -->
        <div class="relative">
          <select id="languageSelect" class="bg-white/20 backdrop-blur-md text-white border border-white/30 rounded-lg px-4 py-2 pr-8 focus:outline-none focus:ring-2 focus:ring-white/50 appearance-none cursor-pointer hover:bg-white/30 transition">
            <option value="en" class="bg-purple-600">English</option>
            <option value="mr" class="bg-purple-600">मराठी (Marathi)</option>
          </select>
          <div class="absolute right-2 top-1/2 transform -translate-y-1/2 pointer-events-none">
            <i class="fas fa-chevron-down text-white text-xs"></i>
          </div>
        </div>
        
        <% if (!currentUser) { %>
          <a href="/" class="hover:text-purple-200 transition font-medium hover:scale-105 transform" data-translate="home">Home</a>
          <a href="/auth/login" class="hover:text-purple-200 transition font-medium hover:scale-105 transform" data-translate="login">Login</a>
          <a href="/auth/register" class="bg-white text-purple-600 px-6 py-2 rounded-lg font-bold hover:shadow-xl transition hover:scale-105 transform" data-translate="register">Register</a>
        <% } else { %>
          <div class="flex items-center gap-6">
            <% if (role === 'student') { %>
              <a href="/student/dashboard" class="hover:text-purple-200 transition hover:scale-105 transform" data-translate="dashboard">Dashboard</a>
            <% } else if (role === 'messKaki') { %>
              <a href="/mess/dashboard" class="hover:text-purple-200 transition hover:scale-105 transform" data-translate="dashboard">Dashboard</a>
            <% } else if (role === 'admin') { %>
              <a href="/admin/dashboard" class="hover:text-purple-200 transition hover:scale-105 transform" data-translate="dashboard">Dashboard</a>
            <% } %>
            <div class="flex items-center gap-3 glass-morphism px-4 py-2 rounded-xl">
              <div class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-lg">
                <i class="fas fa-user text-purple-600"></i>
              </div>
              <div>
                <p class="font-bold text-sm"><%= currentUser.name %></p>
                <p class="text-xs text-purple-200"><%= role === 'messKaki' ? 'Mess Staff' : (role ? role.charAt(0).toUpperCase() + role.slice(1) : 'Guest') %></p>
              </div>
            </div>
            <a href="/auth/logout" class="bg-red-500 px-4 py-2 rounded-lg hover:bg-red-600 transition font-medium hover:scale-105 transform shadow-lg"><i class="fas fa-sign-out-alt"></i> <span data-translate="logout">Logout</span></a>
          </div>
        <% } %>
      </nav>
    </div>
  </div>
</header>

<script>
// Translation system
const translations = {
  en: {
    home: "Home",
    login: "Login",
    register: "Register",
    dashboard: "Dashboard",
    logout: "Logout",
    messStaff: "Mess Staff"
  },
  mr: {
    home: "मुख्यपृष्ठ",
    login: "लॉगिन",
    register: "नोंदणी", 
    dashboard: "डॅशबोर्ड",
    logout: "लॉगआउट",
    messStaff: "मेस स्टाफ"
  }
};

function updateHeaderLanguage() {
  const lang = localStorage.getItem('selectedLanguage') || 'en';
  
  // Update all translatable elements
  document.querySelectorAll('[data-translate]').forEach(element => {
    const key = element.getAttribute('data-translate');
    if (translations[lang] && translations[lang][key]) {
      element.textContent = translations[lang][key];
    }
  });
}

// Language selection functionality
document.getElementById('languageSelect').addEventListener('change', function() {
  const selectedLanguage = this.value;
  
  // Store language preference in localStorage
  localStorage.setItem('selectedLanguage', selectedLanguage);
  
  // Update language immediately
  updateHeaderLanguage();
});

// Set initial language from localStorage
document.addEventListener('DOMContentLoaded', function() {
  const savedLanguage = localStorage.getItem('selectedLanguage');
  if (savedLanguage) {
    document.getElementById('languageSelect').value = savedLanguage;
  }
  updateHeaderLanguage();
});
</script>
